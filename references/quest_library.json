    "reward_scaling_formulas": {
      "gold": {
        "formula": "base_gold * difficulty_multiplier * environment_multiplier * (1 + (player_level / 10))",
        "description": "Gold rewards scale with difficulty, environment, and player level"
      },
      "reputation": {
        "formula": "base_reputation * difficulty_multiplier * (1 + (quest_importance / 5))",
        "description": "Reputation gains increase with difficulty and quest significance"
      },
      "experience": {
        "formula": "base_xp * difficulty_multiplier * (1 + (skills_used / 5))",
        "description": "Experience scales with difficulty and number of skills utilized"
      },
      "item_quality": {
        "formula": "min(5, max(1, difficulty_multiplier * environment_multiplier))",
        "description": "Determines quality tier of rewarded items (1-5)"
      }
    },
    "difficulty_calculations": {
      "combat_encounters": {
        "formula": "50 + (enemy_CV * 2) + (enemy_count * 5) - (party_size * 3)",
        "factors": {
          "enemy_CV": "Combat Value of primary enemies",
          "enemy_count": "Number of enemies",
          "party_size": "Number of player allies"
        }
      },
      "social_interactions": {
        "formula": "50 + (target_importance * 10) + (request_difficulty * 15) - (relationship_bonus * 5)",
        "factors": {
          "target_importance": "Status/importance of NPC (1-5)",
          "request_difficulty": "How unreasonable the request is (1-5)",
          "relationship_bonus": "Current relationship level bonus"
        }
      },
      "skill_challenges": {
        "formula": "50 + (skill_complexity * 10) + (time_pressure * 5) - (tool_quality * 3)",
        "factors": {
          "skill_complexity": "Complexity of task (1-5)",
          "time_pressure": "Urgent deadline (0-10)",
          "tool_quality": "Quality of available tools (1-5)"
        }
      },
      "exploration_challenges": {
        "formula": "50 + (environment_danger * 15) + (distance * 2) - (preparation * 5)",
        "factors": {
          "environment_danger": "Hostility of environment (1-5)",
          "distance": "Distance to travel/cover (in km)",
          "preparation": "Level of preparation (0-10)"
        }
      }
    },
    "quest_generation_guidelines": {
      "balancing_principles": [
        "Quest difficulty should match player capabilities with some challenge",
        "Rewards should feel meaningful but not game-breaking",
        "Environment should enhance the quest theme",
        "Time requirements should be reasonable for the difficulty",
        "Failures should have consequences but not be punitive"
      ],
      "progression_arcs": {
        "beginner": {
          "duration": "1-5 sessions",
          "focus": "Learning mechanics, local area, basic skills",
          "reward_focus": "Immediate needs, skill improvement"
        },
        "intermediate": {
